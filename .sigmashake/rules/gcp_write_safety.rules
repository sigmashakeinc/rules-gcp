# gcp_write_safety.rules
# Technology: gcp | Capability: write

rule gcp-iam-primitive-roles {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*.tf" AND content LINE_REGEX "role\\s*=\\s*[\"']roles/(owner|editor|viewer)[\"']"
  MESSAGE "Using primitive roles (roles/owner, roles/editor, roles/viewer) violates the Principle of Least Privilege. Use predefined or custom roles with precise permissions."
}

rule gcp-public-storage-bucket {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*.tf" AND content LINE_REGEX "members\\s*=\\s*\\[\\s*[\"']allUsers[\"']\\s*\\]" AND content LINE_REGEX "role\\s*=\\s*[\"']roles/storage\\.objectViewer[\"']"
  MESSAGE "Granting allUsers the Storage Object Viewer role makes the bucket public to the internet. This is a primary cause of data leaks. Remove this unless explicitly intended."
}

rule gcp-open-firewall-ssh {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*.tf" AND content LINE_REGEX "source_ranges\\s*=\\s*\\[\\s*[\"']0\\.0\\.0\\.0/0[\"']\\s*\\]" AND content LINE_REGEX "ports\\s*=\\s*\\[\\s*[\"']22[\"']\\s*\\]"
  MESSAGE "Allowing SSH (port 22) access from 0.0.0.0/0 exposes VMs to brute force attacks. Restrict IP ranges or use Identity-Aware Proxy (IAP) instead."
}

rule gcp-ssrf-metadata-server {
  enabled true
  priority 85
  severity warning
  ASK write
  IF path GLOB "**/*.py" AND content LINE_REGEX "requests\\.get\\([\"']http://metadata\\.google\\.internal.*[\"']\\)" AND content NOT CONTAINS "Metadata-Flavor: Google"
  MESSAGE "Querying the GCP metadata server without the 'Metadata-Flavor: Google' header is highly susceptible to Server-Side Request Forgery (SSRF) which can leak service account credentials."
  PROMPT "Are you sure you want to query the metadata server without the required security header? (Metadata-Flavor: Google)"
}
